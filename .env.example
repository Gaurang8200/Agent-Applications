# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Anthropic ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Database ---
POSTGRES_USER=agentapp
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=agent_applications
POSTGRES_HOST=localhost
# 5433, not 5432 — a native Postgres install commonly owns 5432 on the host and
# would shadow the container for localhost connections.
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg://agentapp:change_me_locally@localhost:5433/agent_applications

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO locally, S3 in prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=resumes
S3_REGION=us-east-1

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
